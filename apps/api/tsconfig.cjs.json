{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["es2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "../..",
    "outDir": "dist-cjs",
    "declaration": false,
    "noEmit": false
  },
  "include": [
    "src/**/*.ts",
    "../../packages/config/src/**/*.ts",
    "../../packages/types/src/**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "../../packages/**/*.test.ts",
    "dist/**",
    "dist-cjs/**"
  ]
}
